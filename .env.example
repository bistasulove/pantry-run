# ─────────────────────────────────────────────────────────────────────────
# Supabase — required
# Get these from your Supabase dashboard → Project Settings → API.
# Copy this file to .env.local and fill in real values. Never commit .env.local.
# ─────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# ─────────────────────────────────────────────────────────────────────────
# Gemini — required for Smarter Categories (V2 / M15)
# The categorize_item Edge Function calls Gemini 2.5 Flash (free tier) for
# items the keyword dictionary doesn't recognise. The API key lives in
# Supabase secrets, NOT in this file. Set it once:
#   npx supabase secrets set GEMINI_API_KEY=<your-key>
# For local function testing, put it in supabase/functions/.env (gitignored)
# and run `supabase functions serve --env-file supabase/functions/.env`.
# ─────────────────────────────────────────────────────────────────────────
# GEMINI_API_KEY — set via Supabase secrets / supabase/functions/.env

# ─────────────────────────────────────────────────────────────────────────
# Sentry — optional locally, required in production (V1.1 / M13)
# DSN: Sentry dashboard → Settings → Projects → pantry-run → Client Keys.
# When NEXT_PUBLIC_SENTRY_DSN is unset, Sentry is silently disabled —
# this keeps `npm run dev` quiet on developer machines.
# SENTRY_AUTH_TOKEN is for source-map upload at build time only; set it on
# Vercel (Production + Preview), never in .env.local. Same for SENTRY_ORG /
# SENTRY_PROJECT — they're read by withSentryConfig when uploading.
# ─────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
# Vercel-only:
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=
